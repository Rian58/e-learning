# ─── Dependencies ─────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ──────────────────────────────────────────────
/.next/
/out/
/build

# ─── Testing ──────────────────────────────────────────────
/coverage

# ─── Environment Variables (JANGAN PERNAH COMMIT!) ────────
.env
.env.*
!.env.example

# ─── Prisma ───────────────────────────────────────────────
# Generated Prisma client (auto-generated saat build)
/prisma/generated/
# Migration lock tidak perlu di-ignore, tapi dev snapshot bisa di-ignore
# /prisma/migrations/  <-- JANGAN ignore ini, migrations harus di-commit

# ─── Vercel ───────────────────────────────────────────────
.vercel

# ─── TypeScript ───────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Debug Logs ───────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ─── OS Files ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Editor & IDE ─────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ─── Security ─────────────────────────────────────────────
*.pem
*.key
*.cert

# ─── Scripts Development (utility scripts, bukan production) ──
/scripts/

# ─── Misc ─────────────────────────────────────────────────
*.tgz
.cache/
