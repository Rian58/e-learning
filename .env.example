# ──────────────────────────────────────────────────────────────
#  Stack Sinau — Environment Variables Template
#  Salin file ini menjadi .env dan isi dengan nilai yang benar.
#  cp .env.example .env
# ──────────────────────────────────────────────────────────────

# ─── Supabase (Public — aman diekspos ke browser) ─────────────
# Dapatkan dari: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# ─── Supabase (Secret — JANGAN gunakan prefix NEXT_PUBLIC_!) ──
# ⚠️  Service Role Key memiliki akses penuh ke database!
# Dapatkan dari: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ─── Database ─────────────────────────────────────────────────
# Gunakan Transaction mode (port 6543 + pgbouncer) untuk Vercel serverless
# Dapatkan dari: Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.your-ref:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# Koneksi langsung untuk Prisma migrations (bukan untuk runtime)
DIRECT_URL=postgresql://postgres.your-ref:password@aws-0-region.pooler.supabase.com:5432/postgres

# ─── Google Gemini AI ─────────────────────────────────────────
# ⚠️  JANGAN gunakan prefix NEXT_PUBLIC_ — key ini harus tetap di server!
# Dapatkan dari: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=AIza...your-gemini-key

# ─── Site URL (untuk SEO metadata & OAuth redirect) ───────────
# Development: http://localhost:3000
# Production:  https://stacksinau.henss.my.id
NEXT_PUBLIC_SITE_URL=https://stacksinau.henss.my.id
